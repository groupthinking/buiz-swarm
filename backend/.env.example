# BuizSwarm Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# Application Settings
# ============================================
DEBUG=true
ENVIRONMENT=development
APP_NAME=BuizSwarm
APP_VERSION=1.0.0
BUIZSWARM_API_PORT=8010
BUIZSWARM_BRIDGE_PORT=3016
BUIZSWARM_DB_PORT=5439
BUIZSWARM_REDIS_PORT=6389
BUIZSWARM_FLOWER_PORT=5565

# Security
SECRET_KEY=change-this-to-a-secure-random-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============================================
# Database & Cache
# ============================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/buizswarm
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

REDIS_URL=redis://localhost:6379/0

# ============================================
# AWS Bedrock Configuration
# ============================================
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_BEARER_TOKEN_BEDROCK=
# Use either AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY or AWS_BEARER_TOKEN_BEDROCK.
# Bedrock bearer tokens are short-lived and usually expire within 12 hours.

# Bedrock Model Settings
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
BEDROCK_MAX_TOKENS=4096
BEDROCK_TEMPERATURE=0.7

# ============================================
# MCP (Model Context Protocol)
# ============================================
MCP_SERVER_URL=http://localhost:3000
MCP_TIMEOUT_SECONDS=30

# ============================================
# OpenClaw Runtime Integration
# ============================================
OPENCLAW_HOME=/openclaw
OPENCLAW_GATEWAY_URL=http://host.docker.internal:18789
OPENCLAW_GATEWAY_TOKEN=
# Leave OPENCLAW_GATEWAY_TOKEN blank only when the bridge can read /openclaw/openclaw.json.
# For remote AWS deployments, set OPENCLAW_GATEWAY_TOKEN explicitly.
OPENCLAW_BRIDGE_URL=http://openclaw-bridge:3006
DEFAULT_COMPANY_PROFILE=profitmax
COMPANY_PROFILE_MANIFEST=/openclaw/workspace/projects/profitmax/COMPANY_MANIFEST.json

# ============================================
# Stripe Configuration
# ============================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PLATFORM_FEE_PERCENT=20.0

# ============================================
# GitHub Integration
# ============================================
GITHUB_TOKEN=ghp_your_github_personal_access_token
GITHUB_ORG=your-github-organization

# ============================================
# Email (SendGrid)
# ============================================
SENDGRID_API_KEY=SG.your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@buizswarm.com

# ============================================
# Meta Ads API
# ============================================
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_ACCESS_TOKEN=your-meta-access-token

# ============================================
# Infrastructure Provisioning
# ============================================
AWS_INFRA_REGION=us-west-2
RENDER_API_KEY=rnd_your_render_api_key
NEON_API_KEY=your_neon_api_key

# ============================================
# Agent Configuration
# ============================================
AGENT_DAILY_CYCLE_HOUR=9
AGENT_MAX_CONCURRENT_TASKS=10
AGENT_TASK_TIMEOUT_SECONDS=300

# ============================================
# Monitoring & Logging
# ============================================
LOG_LEVEL=INFO
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ============================================
# Multi-tenancy Limits
# ============================================
MAX_COMPANIES_PER_USER=10
MAX_CONCURRENT_COMPANIES=1000
